AZURE_OPENAI_ENDPOINT="https://<your-resource>.openai.azure.com/"
AZURE_OPENAI_API_KEY="<set-in-render-or-local>"
AZURE_OPENAI_API_VERSION="2025-01-01-preview"
AZURE_OPENAI_DEPLOYMENT_NAME="<your-deployment-name>"

# Azure DevOps Configuration
AZURE_DEVOPS_ORG="https://dev.azure.com/<your-org>"
AZURE_DEVOPS_PROJECT="<your-project>"
AZURE_DEVOPS_PAT="<set-in-render-or-local>"
AZURE_DEVOPS_WORK_ITEM_TYPE="User Story"

# Azure AD/MSAL Configuration (optional)
AZURE_CLIENT_ID="<optional>"
AZURE_TENANT_ID="<optional>"

# Server Configuration
BACKEND_PORT=8000
CORS_ORIGINS="*"
